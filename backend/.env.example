# ─── Supabase ───────────────────────────────────────────────
# El backend usa el SERVICE_KEY (bypass RLS). ANON_KEY no es requerida.
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# ─── Server ─────────────────────────────────────────────────
PORT=3000
# Solo necesario si el frontend corre en un origin distinto (dev con
# Vite en :5173, o deploy separado del backend).
FRONTEND_URL=http://localhost:5173

# ─── Integración Rocket Ecuador ─────────────────────────────
# Secreto que Rocket debe incluir en la URL del webhook
# (POST /api/webhooks/rocket/<SECRET>). Fail-closed si está vacío.
ROCKET_WEBHOOK_SECRET=

# ─── Matching de productos por IA (opcional) ────────────────
# Habilita el auto-match con Claude Haiku en imports de Excel de Rocket.
# Si está vacía, el matcher opera como no-op y la import sigue funcionando.
ANTHROPIC_API_KEY=

# ─── Push notifications (opcional) ──────────────────────────
# Service account JSON completo en una sola línea (usar `jq -c . file.json`).
FIREBASE_SERVICE_ACCOUNT_JSON=
